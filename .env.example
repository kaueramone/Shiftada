# ============================================================
# SHIFTADA — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local or any file with real credentials.
# ============================================================

# ---------------------------
# SUPABASE
# ---------------------------
# Found in: Supabase Dashboard → Settings → API

# Public anon key (safe to expose client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER ONLY, NEVER expose to client
# Used only in server-side code / API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------------------------
# APP
# ---------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
